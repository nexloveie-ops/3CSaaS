# Copy to .env.local (never commit secrets)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.hgfe01j.mongodb.net/lz3c?appName=Cluster0
MONGODB_DB_NAME=lz3c
PORT=3000
HOST=0.0.0.0
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173
WEB_APP_URL=http://localhost:5173

# Stripe subscription (optional — dev mode activates plans without Stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Comma-separated emails granted Super Admin on register
SUPER_ADMIN_EMAILS=admin@lz3c.local

# Invoice PDF storage (local folder when GCS_BUCKET unset)
LOCAL_STORAGE_PATH=./data
GCS_BUCKET=
GCS_PROJECT_ID=

# PDF: production Docker uses chromium; local dev uses puppeteer (downloads Chrome)
# PUPPETEER_EXECUTABLE_PATH=
# USE_CHROMIUM=1

# Email PDF (SendGrid — optional; logs mock if unset)
SENDGRID_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# Company webhook URL (optional) — set per company via PATCH /companies/:id/settings
# AUDIT_AUTO_PURGE=1
# AUDIT_AUTO_PURGE_HOURS=24
# AUDIT_PURGE_NOTIFY=1

# Twilio (repairs SMS — optional; logs mock message if unset)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+353...
