# Web SPA + nginx (proxies /api to backend)
FROM node:22-alpine AS builder
WORKDIR /app

COPY package.json package-lock.json* ./
COPY packages/shared/package.json ./packages/shared/
COPY packages/db/package.json ./packages/db/
COPY apps/api/package.json ./apps/api/
COPY apps/web/package.json ./apps/web/

RUN npm ci

COPY packages/shared ./packages/shared
COPY apps/web ./apps/web

RUN npm run build -w @lz3c/shared
RUN npm run build -w @lz3c/web

FROM nginx:1.27-alpine AS runner
RUN apk add --no-cache gettext

COPY --from=builder /app/apps/web/dist /usr/share/nginx/html
COPY infra/nginx.conf.template /etc/nginx/templates/default.conf.template
COPY infra/docker-entrypoint-web.sh /docker-entrypoint-web.sh
RUN chmod +x /docker-entrypoint-web.sh

ENV API_UPSTREAM=http://api:3000/api/
EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD wget -qO- http://127.0.0.1:8080/ || exit 1

ENTRYPOINT ["/docker-entrypoint-web.sh"]
