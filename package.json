{
  "name": "lz3c",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w @lz3c/api",
    "dev:web": "npm run dev -w @lz3c/web",
    "build": "npm run build -w @lz3c/shared && npm run build -w @lz3c/db && npm run build -w @lz3c/api",
    "build:web": "npm run build -w @lz3c/web",
    "docker:api:build": "docker build -f infra/Dockerfile -t lz3c-api:local .",
    "docker:web:build": "docker build -f infra/Dockerfile.web -t lz3c-web:local .",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "test:mongo": "node scripts/test-mongo.mjs",
    "test:smoke": "node scripts/smoke-test.mjs",
    "test:smoke:cashier-store": "node scripts/smoke-cashier-store.mjs",
    "test:smoke:catalog": "node scripts/smoke-catalog.mjs",
